    Identity["bayer-ai-identity\n(Managed Identity)"]

    %% CI/CD Flow
    GHA -->|"1. push image"| Image
    GHA -->|"2. trigger migrate job"| MigrateJob
    GHA -->|"3. deploy app"| App
    GHA -->|"4. deploy function"| IngestFn

    %% Migration
    MigrateJob -->|"pulls image"| Image
    MigrateJob -->|"alembic upgrade head"| PG

    %% User query flow
    User -->|"POST /ask"| App
    App -->|"vector search"| ChromaDB
    App -->|"read/write session history"| PG
    App -->|"read secrets"| KV

    %% ChromaDB persistence
    ChromaDB <-->|"Azure Files volume mount"| ChromaStorage

    %% Ingestion pipeline
    User -->|"upload document"| DocStorage
    DocStorage -->|"BlobCreated event"| IngestFn
    IngestFn -->|"download blob"| DocStorage
    IngestFn -->|"chunk → embed → upsert"| ChromaDB
    IngestFn -->|"read secrets"| KV

    %% Identity (passwordless auth)
    Identity -.->|"assigned to"| App
    Identity -.->|"assigned to"| IngestFn
    Identity -.->|"grants access to"| KV
    Identity -.->|"grants Blob Reader"| DocStorage

    %% Observability
    IngestFn -->|"telemetry"| AppInsights
    AppInsights -->|"logs sink"| LogWS
    AppInsights -->|"anomaly alerts"| AlertGroup
