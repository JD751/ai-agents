ENV=local
LOG_LEVEL=INFO
OPENAI_API_KEY=

# PostgreSQL — individual vars used by docker-compose to initialise the container
POSTGRES_USER=bayeruser
POSTGRES_PASSWORD=bayerpass
POSTGRES_DB=bayerai

# Full DSN used by SQLAlchemy (asyncpg) and LangGraph checkpointer (psycopg)
# Local: use @localhost:5432  |  Docker Compose app service: use @postgres:5432
# Azure: injected by Container Apps pointing at Azure Database for PostgreSQL
DATABASE_URL=postgresql+asyncpg://bayeruser:bayerpass@localhost:5432/bayerai

AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=documents
# Workaround for chromadb pulling in old opentelemetry _pb2.py files incompatible with protobuf 4+
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python
ANONYMIZED_TELEMETRY=false
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=bayer-ai